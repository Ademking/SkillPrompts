{
  "name": "skillprompts",
  "displayName": "SkillPrompts",
  "version": "1.0.0",
  "description": "A Chrome extension to manage and use skill prompts for ChatGPT.",
  "author": "Adem Kouki <ademkingnew@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*",
      "https://copilot.microsoft.com/*",
      "https://huggingface.co/chat/*",
      "https://chat.mistral.ai/*",
      "https://poe.com/*",
      "https://www.perplexity.ai/*",
      "https://chat.deepseek.com/*",
      "https://kimi.com/*",
      "https://*.kimi.com/*",
      "https://m365.cloud.microsoft/*",
      "https://v0.app/*",
      "https://github.com/copilot/*",
      "https://grok.com/*",
      "https://cursor.com/agents*",
      "https://cursor.com/*/agents*"
    ]
  }
}